        {
            "name": "QEMU 调试（可重启/停止）",
            "type": "lldb",
            "request": "attach",
            "targetCreateCommands": ["target create ${workspaceFolder}/build/kernel.elf"],
            "processCreateCommands": ["gdb-remote localhost:1234"],
            "preLaunchTask": "ubuntu启动 QEMU 调试服务器",
            "preRunCommands": [
                "shell sleep 0.5"
            ],
            "preTerminateCommands": [
                "shell pkill -f qemu-system-aarch64"
            ],
            "stopOnEntry": false
        },

        {
            "name": "QEMU ARM64 内核调试 (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/kernel.elf",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/Users/chanpinkaifa/scoop/apps/bin/aarch64-none-elf-gdb.exe",
            "miDebuggerServerAddress": "localhost:1234",
            "preLaunchTask": "windows启动 QEMU 调试服务器",
        },
        {
            "name": "QEMU ARM64 内核调试 (Linux GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/kernel.elf",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb-multiarch",
            "miDebuggerServerAddress": "localhost:1234",
            "preLaunchTask": "ubuntu启动 QEMU 调试服务器",
        }
    ]
}