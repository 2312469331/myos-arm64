{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ubuntu启动 QEMU 调试服务器",
            "type": "shell",
    "command": "gnome-terminal --title=\"QEMU AArch64 调试\" -- bash -i -c \"cd ${workspaceFolder} && ./tools/debug_ubuntu.sh\"",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "isBackground": false,
            "runOptions": {
                "runOn": "default"
            }
            
        },
        {
            "label": "windows启动 QEMU 调试服务器",
            "type": "shell",
            "command": "./tools/debug_windows.sh &",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "isBackground": false
        },
         {
            "label": "make clean + compile_commands",
            "type": "shell",
            "linux": {
                "command": "make clean && (command -v compiledb >/dev/null && compiledb make -j$(nproc) || (command -v bear >/dev/null && bear -- make -j$(nproc) || make -j$(nproc)))"
            },
            "windows": {
                "command": "make clean && (Get-Command compiledb.exe -ErrorAction SilentlyContinue) ? (compiledb.exe make -j$env:NUMBER_OF_PROCESSORS) : ((Get-Command bear.exe -ErrorAction SilentlyContinue) ? (bear -- make -j$env:NUMBER_OF_PROCESSORS) : (make -j$env:NUMBER_OF_PROCESSORS))"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}